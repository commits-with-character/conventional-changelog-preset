{
  "name": "@commits-with-character/conventional-changelog-preset",
  "version": "6.0.0",
  "description": "commits-with-character.org preset for conventional-changelog.",
  "keywords": [
    "conventional-changelog",
    "commits-with-character.org",
    "preset"
  ],
  "homepage": "https://commits-with-character.org",
  "bugs": {
    "url": "https://github.com/commits-with-character/conventional-changelog-preset/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/commits-with-character/conventional-changelog-preset.git"
  },
  "license": "ISC",
  "author": "Will Stone",
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "eslint .",
    "prepare": "husky",
    "release": "release-it",
    "test": "vitest"
  },
  "lint-staged": {
    "*.{css,json,md,js,cjs,mjs}": [
      "prettier --write"
    ],
    "*.{js,cjs,mjs,json}": [
      "eslint --fix"
    ]
  },
  "prettier": "@will-stone/prettier-config",
  "overrides": {
    "eslint": "$eslint"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.0",
    "@vitest/eslint-plugin": "^1.6.16",
    "@will-stone/eslint-config": "^26.2.0",
    "@will-stone/prettier-config": "^12.0.0",
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-core": "^9.0.0",
    "conventional-recommended-bump": "^11.2.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "release-it": "^20.0.1",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@release-it/conventional-changelog": "^11.0.0",
    "release-it": "^20.0.1"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
